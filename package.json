{
  "name": "minecraft-broadcaster",
  "version": "0.1.0",
  "description": "Standalone Minecraft Bedrock / Xbox Broadcaster in Node.js and TypeScript",
  "main": "dist/main.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "rimraf dist && esbuild src/main.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/main.js --packages=external",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/main.ts",
    "start:js": "node dist/main.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "minecraft",
    "bedrock",
    "xbox",
    "broadcast",
    "nethernet",
    "typescript"
  ],
  "license": "GPL-3.0",
  "type": "commonjs",
  "dependencies": {
    "bedrock-protocol": "^3.56.1",
    "better-sqlite3": "^12.10.0",
    "nethernet": "^0.1.0",
    "prismarine-auth": "^3.1.1",
    "ws": "^8.21.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "private": false,
  "files": [
    "dist",
    "src",
    "config.example.yml",
    "README.md",
    "LICENSE"
  ]
}
